{
  "ConnectionStrings": {
    "HRNexusDatabase": "Server=MUSTAFA;Database=HRNexus_CleanTest;Trusted_Connection=True;MultipleActiveResultSets=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "HRNexus",
    "Audience": "HRNexus.Client",
    "AccessTokenExpirationMinutes": 30
  },
  "AuthSecurity": {
    "RefreshTokenExpirationDays": 14,
    "MaxFailedLoginAttempts": 5,
    "Argon2TimeCost": 3,
    "Argon2MemoryCost": 65536,
    "Argon2Parallelism": 1,
    "Argon2HashLength": 32
  },
  "DevelopmentAuth": {
    "PasswordBootstrapEnabled": true
  },
  "FileStorage": {
    "LeaveAttachmentsFolder": "LeaveAttachments",
    "PersonPhotosFolder": "PersonPhotos",
    "EmployeeDocumentsFolder": "EmployeeDocuments",
    "MaxFileSizeBytes": 10485760,
    "AllowedAttachmentExtensions": [
      ".pdf",
      ".doc",
      ".docx",
      ".jpg",
      ".jpeg",
      ".png",
      ".webp",
      ".txt"
    ],
    "AllowedPhotoExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
